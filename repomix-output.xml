#                 learning_rate=LR, n_steps=ROLLOUT_STEPS, batch_size=BATCH_SIZE,
#                 verbose=1)
#     model.learn(total_timesteps=TOTAL_TIMESTEPS)
#     model.save("sb3_policy")


if __name__ == "__main__":
    train()
