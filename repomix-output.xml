import os
import time
import torch
import gymnasium as gym
import numpy as np
from ppo_agent import PPOAgent

scenario = "Pendulum-v1"
env = gym.make(scenario)

NUM_EPISODES = 1000
NUM_STEP = 200
best_reward = -2000
REWARD_BUFFER = np.empty(shape=NUM_EPISODES)

STATE_DIM = env.observation_space.shape[0]
ACTION_DIM = env.action_space.shape[0]
BATCH_SIZE = 25
UPDATE_INTERVAL = 50
agent = PPOAgent(STATE_DIM, ACTION_DIM, BATCH_SIZE)

# save model
current_path = os.path.dirname(os.path.realpath(__file__))
model = current_path + "/models/"
timestamp = time.strftime("%Y%m%d-%H%M%S")

for episode_i in range(NUM_EPISODES):
    done = False
    state, others = env.reset() # 初始化环境，获得当前state
    episode_reward = 0

    for step_i in range(NUM_STEP):
        action, value = agent.get_action(state) # 根据state决策action
        next_state, reward, done, truncated, info = env.step(action)
        episode_reward += reward
        done = True if step_i == NUM_STEP - 1 else done
        agent.replay_buffer.add_memory(state, action, reward, value, done)
        state = next_state

        if (step_i + 1) % UPDATE_INTERVAL == 0 or step_i == NUM_STEP - 1:
            agent.update()

    if episode_reward > -100 and episode_reward > best_reward:
        best_reward = episode_reward
        agent.save_policy()
        torch.save(agent.actor.state_dict(), model + f"ppo_actor_{timestamp}.pth")
        print(f"Best Reward: {best_reward}")

    REWARD_BUFFER[episode_i] = episode_reward
    print(f"Episode: {episode_i}, Reward: {round(episode_reward, 2)}")

env.close()
